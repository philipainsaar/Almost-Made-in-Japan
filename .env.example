# Your Shopify store domain. Example: almost-made-in-japan.myshopify.com
SHOPIFY_STORE_DOMAIN="your-store.myshopify.com"

# Storefront API version. Keep this synced with Shopify docs when you upgrade.
SHOPIFY_STOREFRONT_API_VERSION="2026-07"

# Recommended for this Next.js server-side storefront:
SHOPIFY_STOREFRONT_PRIVATE_TOKEN=""

# Optional fallback. The app only sends this from server routes, never directly from the browser.
SHOPIFY_STOREFRONT_PUBLIC_TOKEN=""

# Main product collection shown in Favourites / Latest Creation.
SHOPIFY_JEWELRY_COLLECTION_HANDLE="jewelry"

# Category tiles shown under JEWELLERY.
SHOPIFY_CATEGORY_HANDLES="necklaces,earrings,hair-clips,rings,accessories,sunglasses"

# Collection tiles shown under COLLECTIONS.
SHOPIFY_COLLECTION_HANDLES="dreamy,emo,nature,cyber"

# Country code used for contextual pricing.
SHOPIFY_COUNTRY_CODE="SE"
